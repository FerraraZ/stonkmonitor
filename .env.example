# ============================================================
#  STONK MONITOR — Environment Variables
#  Copy this to .env and fill in your real keys
# ============================================================

# --- Unusual Whales ---
UNUSUAL_WHALES_API_KEY=your_uw_api_key_here

# --- Alpaca (Paper Trading) ---
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_PAPER=true   # set to false for live trading
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- SEC-API.io (Insider Trades) ---
SEC_API_KEY=your_sec_api_key_here

# --- Discord ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# --- Pushover ---
PUSHOVER_API_TOKEN=your_pushover_app_token
PUSHOVER_USER_KEY=your_pushover_user_key

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Signal Engine Thresholds (tune these!) ---
MIN_PREMIUM_ALERT=50000       # minimum $ premium for options flow alert
MIN_DARKPOOL_SIZE=100000      # minimum $ for dark pool print alert
IV_RANK_THRESHOLD=80          # alert when IV rank > this (0-100)
IV_RANK_LOW_THRESHOLD=20      # alert when IV rank < this (buying cheap options)
SWEEP_SCORE_THRESHOLD=7       # 1-10 score to trigger notification
